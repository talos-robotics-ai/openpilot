<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>policypilot</name>
  <version>0.1.0</version>
  <description>
    ROS 2 application layer for the Unitree G1 humanoid.
    Bundles the RoboJuDo RL policy runtime under policy_runtime/ and
    supervises it through a single policy_manager ROS node.
  </description>
  <maintainer email="massimiliano.menzolini@example.com">Massimiliano Menzolini</maintainer>
  <license>BSD 3</license>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
